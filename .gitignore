# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Database ──────────────────────────────────────────────────────────────────
# The SQLite database file is runtime data, not source code.
# Railway/Render will persist this via volume mounts.
database/*.db
database/*.db-shm
database/*.db-wal

# ── Build / Dist ──────────────────────────────────────────────────────────────
dist/
build/
.cache/

# ── Capacitor (Mobile) ────────────────────────────────────────────────────────
# ios/ and android/ are generated by `npx cap add ios` / `npx cap add android`
# Commit them once generated so CI can build, or keep them ignored during early dev.
# Uncomment the lines below to ignore generated native projects:
# ios/
# android/
.gradle/
*.keystore
!debug.keystore
*.jks

# ── macOS / Windows ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Coverage ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
