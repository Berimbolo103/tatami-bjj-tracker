# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Admin ─────────────────────────────────────────────────────────────────────
# Change this to a strong random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=tatami-admin-2024

# ── Database ──────────────────────────────────────────────────────────────────
# Directory where tatami.db will be stored.
# On Railway: point to your volume mount path (e.g. /data)
# Locally: leave blank to use ./database/
DB_DIR=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origins for API requests (comma-separated).
# In development this is set to * automatically.
# In production set this to your deployed URL:
# ALLOWED_ORIGINS=https://tatami-bjj.up.railway.app
ALLOWED_ORIGINS=*

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
